	spriteType = { #Only buttons can be animated. IconTypes cannot. Buttons that are animated have the animation halted when hovered over.
		name = "GFX_stargate_planet_terminal_dial"
		texturefile = "gfx/event_pictures/custom_uis/stargate_anim_1-and-a-half_mask_blank.dds" #The base image. Defines the size of the sprite.
		effectFile = "gfx/FX/buttonstate.shader"
		noOfFrames = 1
		animation = {
			animationmaskfile = "gfx/event_pictures/custom_uis/stargate_anim_1-and-a-half_mask.dds" #The shape of the animation. Whitespace appears to define where the animation appears.
			animationtexturefile = "gfx/event_pictures/custom_uis/stargate_anim_2_spin.dds" #The image to animate.
			animationrotation = 0.0
			animationlooping = yes
			animationtime = 7
			animationdelay = 0
			animationblendmode = "add"
			animationtype = "rotating"  #scrolling, rotating, pulsing
			animationrotationoffset = { x = 0.0 y = 0.0 }
			animationtexturescale = { x = 1.0 y = 1.0 }
			animationframes = { 1 }
		}
		legacy_lazy_load = no
	}
