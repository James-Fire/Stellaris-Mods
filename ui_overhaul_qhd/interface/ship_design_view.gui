				position = { x = 120 y = 60 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = right
				vertical_alignment = center
			}
			instantTextBoxType = {
				name = "speed"
				text = "SHIP_STAT_SPEED_INLINE"
				font = "font_text_14"
				position = { x = 10 y = 85 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = left
				vertical_alignment = center
				pdx_tooltip = "SHIP_STAT_DESC_combat_speed"
			}
			instantTextBoxType = {
				name = "speed_value"
				text = ""
				font = "font_text_14"
				position = { x = 120 y = 85 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = right
				vertical_alignment = center
			}
			instantTextBoxType = {
				name = "evasion"
				text = "SHIP_STAT_EVASION_INLINE"
				font = "font_text_14"
				position = { x = 10 y = 110 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = left
				vertical_alignment = center
				pdx_tooltip = "SHIP_STAT_DESC_evasion"
			}
			instantTextBoxType = {
				name = "evasion_value"
				text = ""
				font = "font_text_14"
				position = { x = 120 y = 110 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = right
				vertical_alignment = center
			}
			instantTextBoxType = {
				name = "damage"
				text = "SHIP_STAT_DAMAGE_INLINE"
				font = "font_text_14"
				position = { x = 10 y = 135 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = left
				vertical_alignment = center
				pdx_tooltip = "SHIP_STAT_DESC_damage"
			}
			instantTextBoxType = {
				name = "damage_value"
				text = ""
				font = "font_text_14"
				position = { x = 125 y = 135 }
				maxWidth = 125
				maxHeight = 20
				fixedSize = yes
				format = right
				vertical_alignment = center
			}
		}
		# core components
		instantTextBoxType = {
			name = "label"
			font = "font_text_14"
			text = "FLEET_VIEW_COMPONENTS_LABEL"
			position = { x = 20 y = 305 }
			maxWidth = 500
			maxHeight = 20
			fixedSize = yes
			format = left
			vertical_alignment = center
			#alwaysTransparent = yes 
		}
		containerWindowType = {
			name = "components"
			size = { width = 750 height = 76 }
			position = { x = 10 y = 320 }
			verticalScrollbar = "right_vertical_slider_thick"
			margin = { top = 8 right = 9 bottom = 8 left = 9 }
			background = {
				name = "components"
				spriteType = "GFX_tiles_frame_light"
			}
			gridBoxType = {
				name = "components"
				position = { x = 0 y = 0 }
				size = { width = 735 height = -5 }
				slotSize = { width = 56 height = 56 }
				format = "UPPER_LEFT"
				max_slots_horizontal = 13
			}
		}
		# armaments and utilities
		smoothListboxType = {
			name = "component_sets"
			size = { x = @col1_w y = 450 }
			position = { x = 10 y = 401 }
			spacing = 0
		}
	}
