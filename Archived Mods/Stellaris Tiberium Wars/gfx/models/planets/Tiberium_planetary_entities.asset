entity = {
	name = "habitable_tiberium_planet_01_entity"
	pdxmesh = "planet_clouded_mesh"
	
	meshsettings = {
	name = "planet_geosphereShape"
	texture_diffuse = "pc_habitable_tiberium_planet_diffuse.dds"
	texture_normal = "pc_habitable_tiberium_planet_normal.dds"
	texture_specular = "pc_habitable_tiberium_planet_specular.dds"
	}
	
	##cloud texture override
	meshsettings = {
	name = "clouds_geosphereShape"
	texture_diffuse = "clouds_thin_diffuse.dds"
	texture_normal = "clouds_thin_normal.dds"
	texture_specular = "clouds_thin_specular.dds"
	}
	
	##cloud shadow texture override
	meshsettings = {
	name = "clouds_shadow_geosphereShape"
	texture_diffuse = "clouds_thin_shadow_diffuse.dds"
	texture_normal = "nonormal.dds"
	texture_specular = "nospec.dds"
	}
	
	default_state = "idle"	
	state = { name = "idle" animation = "idle" time_offset = { 0 100 } 
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class" } }
	}
}

entity = {
	name = "uninhabitable_tiberium_planet_01_entity"
